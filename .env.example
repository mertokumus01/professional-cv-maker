# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cv_builder_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_DIALECT=postgres

# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug
APP_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_REFRESH_EXPIRE=30d

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_APP_NAME=CV Builder

# Email Configuration
EMAIL_ENABLED=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@cvbuilder.com
EMAIL_FROM_NAME=CV Builder

# Email Notification Preferences
SEND_WELCOME_EMAIL=true
SEND_CV_CREATED_EMAIL=true
SEND_CV_UPDATED_EMAIL=true
SEND_PASSWORD_RESET_EMAIL=true
SEND_SECURITY_ALERTS=true
SEND_WEEKLY_DIGEST=false

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf

# AWS S3 Configuration (Optional)
AWS_ENABLED=false
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=us-east-1

# Redis Configuration (Optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google Analytics (Optional)
GOOGLE_ANALYTICS_ID=

# OAuth2 Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id

# Base URLs
BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_TO_FILE=false
LOG_FILE_PATH=./logs

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 2FA Secret (optional, auto-generated by the app)
TOTP_WINDOW=2

# API Keys
API_KEY_PREFIX=cv_
API_KEY_EXPIRY_DAYS=365

# Session Management
SESSION_SECRET=your_session_secret_here
SESSION_TIMEOUT=3600000
SESSION_ENABLED=true

# Account Security
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15
PASSWORD_RESET_TOKEN_EXPIRES_HOURS=24
EMAIL_VERIFICATION_TOKEN_EXPIRES_HOURS=48

# Feature Flags
ENABLE_2FA=true
ENABLE_SOCIAL_LOGIN=true
ENABLE_PDF_EXPORT=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET=true
ENABLE_ACCOUNT_LOCKOUT=true
ENABLE_API_KEYS=true

# Monitoring & Analytics
SENTRY_DSN=
DATADOG_API_KEY=
MONITORING_ENABLED=false

# Search & Indexing
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200

# File Export
ENABLE_PDF_EXPORT=true
ENABLE_DOCX_EXPORT=true
ENABLE_CSV_EXPORT=true
ENABLE_JSON_EXPORT=true
EXPORT_TEMP_DIR=./exports

# Backend Security Headers
HELMET_ENABLED=true
HELMET_CSP_ENABLED=true
HELMET_HSTS_MAX_AGE=31536000

# Encryption
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_KEY=your_encryption_key_here_min_32_chars

# Backup
BACKUP_ENABLED=false
BACKUP_FREQUENCY_HOURS=24
BACKUP_RETENTION_DAYS=30

